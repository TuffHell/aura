# AURA talk picks a backend automatically, in this order:
#   1. Claude   — if ANTHROPIC_API_KEY is set (best quality; billed per turn)
#   2. Local AI — if an Ollama server is running (free, private, on-device)
#   3. Offline  — curated responder, always available ($0, canned)

# --- Option 1: Claude (paid) -------------------------------------------------
# Billed per spoken turn against this key.
ANTHROPIC_API_KEY=
# claude-haiku-4-5 (~$1/$5) | claude-sonnet-4-6 (~$3/$15) | claude-opus-4-8 (~$5/$25)
AURA_MODEL=claude-haiku-4-5

# --- Option 2: Local AI via Ollama (free) ------------------------------------
# Leave ANTHROPIC_API_KEY blank and run a local model:
#   brew install ollama && ollama serve &
#   ollama pull qwen2.5:7b
# The server auto-detects Ollama at the URL below; no key, nothing leaves the Mac.
AURA_OLLAMA_URL=http://localhost:11434
AURA_OLLAMA_MODEL=qwen2.5:7b
